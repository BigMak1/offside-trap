# Local Claude Code config & skills — not part of the game
.claude/

# Dependencies
node_modules/

# Deploy / build / QA artifacts
.vercel/
.playwright-mcp/
assets/_build/_*.png

# Working docs, task notes & input media — kept local, out of the public repo
.ai/
docs/
pitch.md

# Build output is regenerable and stays out of git — EXCEPT the showcase media
# below (gameplay GIF, screenshots, TikTok clips, presentation), which we publish.
# NOTE: dist/.itch-key (the itch.io API key) and itch-build/*.zip stay ignored.
dist/*
!dist/itch-assets/
!dist/tiktok/
!dist/presentation/

# Temp scratch & screenshots at the repo root (keep the repo clean for agents).
# Root-anchored so they don't accidentally ignore committed media under dist/.
/*.png
/ot-*.png
/ot-frames*.json
/page-*.png
/screenshot*.png
*.log
*.tmp

# OS
.DS_Store
Thumbs.db
